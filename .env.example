# ═══════════════════════════════════════════════════════════════
#  AEQUITAS — Environment Variables
#  Copy this file: cp .env.example .env
#  Fill in real values. NEVER commit .env to Git.
# ═══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-in-production
LOG_LEVEL=INFO

# ── Database (PostgreSQL) ─────────────────────────────────────
# Local dev:  postgresql://aequitas:aequitas@localhost:5432/aequitas
# Railway:    copy the DATABASE_URL from your Railway project
DATABASE_URL=postgresql://aequitas:aequitas@localhost:5432/aequitas
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Cache & queue (Redis) ─────────────────────────────────────
# Local dev:  redis://localhost:6379/0
# Railway:    copy the REDIS_URL from your Railway project
REDIS_URL=redis://localhost:6379/0

# ── AI / LLM ──────────────────────────────────────────────────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Market data ───────────────────────────────────────────────
# Polygon.io free tier: polygon.io/dashboard
POLYGON_API_KEY=your-polygon-key-here

# yFinance needs no key — it's free and open
# EDGAR needs no key — it's a public US government API

# ── Reddit (alternative data) ─────────────────────────────────
# Create app at: reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=aequitas-research-bot/1.0

# ── Auth (JWT) ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-random-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────────────────
# Local dev frontend origin. In production: your Vercel URL
CORS_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ────────────────────────────────────────
# These are prefixed NEXT_PUBLIC_ so they're available in the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
